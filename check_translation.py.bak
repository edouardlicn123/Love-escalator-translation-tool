            await loadDbStatus();
        }
        
        async function backupDb() {
            const resp = await fetch('/api/db/backup', {method: 'POST'});
            const data = await resp.json();
            if (data.success) {
                alert('备份成功: ' + data.path);
            } else {
                alert('备份失败: ' + data.error);
            }
        }
        
        async function applyFilter() {
            const selectedRules = [];
            ['cn_empty', 'placeholder', 'length_abnormal', 'same_content', 'digit_placeholder', 'low_quality'].forEach(r => {
                if (document.getElementById(r).checked) selectedRules.push(r);
            });
            
            const apiSource = document.getElementById('api-select').value;
            
            const resp = await fetch('/api/filter', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({rules: selectedRules, api: apiSource})
            });
            const data = await resp.json();
            issues = data.issues;
            currentIdx = 0;
            document.getElementById('issue-count').textContent = data.total;
            renderItem();
        }
        
        function renderItem() {
            if (issues.length === 0) {
                document.getElementById('issues-list').innerHTML = '<p>请勾选过滤条件或点击下方按钮查看所有</p><button class="btn btn-green" onclick="showAll()">显示全部翻译</button>';
                return;
            }
            if (currentIdx >= issues.length) {
                document.getElementById('issues-list').innerHTML = '<p>没有更多问题</p>';
                return;
            }
            const issue = issues[currentIdx];
            const item = issue.item;
            document.getElementById('issues-list').innerHTML = `
                <div class="issue-item">
                    <div class="meta">文件: ${issue.file} | 索引: ${issue.index}</div>
                    <div class="progress">进度: ${currentIdx + 1} / ${issues.length} | 问题: ${issue.issues.join(', ')}</div>
                    <div class="label">原文 (jp):</div>
                    <div class="jp">${item.jp || '(空)'}</div>
                    <div class="label">当前翻译 (cn):</div>
                    <div class="cn">${item.cn || '(空)'}</div>
                    <div class="label">AI建议:</div>
                    <div class="ai-row">
                        <textarea id="ai-textarea" rows="3">${item.cn || ''}</textarea>
                        <button class="btn-copy" onclick="copyText()" title="复制">📋复制</button>
                    </div>
                    <div class="btn-row">
                        <button class="btn-save" onclick="saveAndNext()">保存→跳转</button>
                    </div>
                </div>
            `;
            loadAISuggestion(item.jp);
        }
        
        function copyText() {
            const textarea = document.getElementById('ai-textarea');
            textarea.select();
            document.execCommand('copy');
            const btn = document.querySelector('.btn-copy');
            btn.textContent = '✓已复制';
            setTimeout(() => btn.textContent = '📋复制', 2000);
        }
        
        async function loadAISuggestion(text) {
            if (!text) return;
            const apiSource = document.getElementById('api-select').value;
            const resp = await fetch('/api/translate', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({text: text, api: apiSource})
            });
            const data = await resp.json();
            const textarea = document.getElementById('ai-textarea');
            if (data.translation && !data.translation.includes('错误') && !data.translation.includes('失败')) {
                textarea.value = data.translation;
            } else if (data.translation) {
                textarea.value = '';
                textarea.placeholder = data.translation;
            }
        }
        
        async function showAll() {
            currentIdx = 0;
            issues = allItems;
            document.getElementById('issue-count').textContent = issues.length;
            renderItem();
        }
        
        async function saveAndReload(cn) {
            const issue = issues[currentIdx];
            const resp = await fetch('/api/update', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({file: issue.file, index: issue.index, cn: cn})
            });
            const data = await resp.json();
            if (data.success) {
                await loadDbStatus();
                nextItem();
            }
        }
        
        async function saveAndNext() {
            const cn = document.getElementById('ai-textarea').value;
            if (cn) await saveAndReload(cn);
        }
        
        async function manualSaveAndNext() {
            const cn = document.getElementById('ai-textarea').value;
            if (cn) await saveAndReload(cn);
        }
        
        function prevItem() { if (currentIdx > 0) { currentIdx--; renderItem(); } }
        function nextItem() { currentIdx++; renderItem(); }
        function jumpToItem() {
            const input = document.getElementById('jump-input');
            const num = parseInt(input.value);
            if (!num || num < 1) {
                alert('请输入有效的数字');
                return;
            }
            if (issues.length === 0) {
                alert('当前没有数据，请先应用过滤');
                return;
            }
            if (num > issues.length) {
                alert('超出范围，当前只有 ' + issues.length + ' 条');
                input.value = issues.length;
                return;
            }
            currentIdx = num - 1;
            renderItem();
        }
        
        init();
    </script>
</body>
</html>
'''

class Handler(BaseHTTPRequestHandler):
    def log_message(self, format, *args): pass
    
    def send_json(self, data):
        self.send_response(200)
        self.send_header('Content-Type', 'application/json')
        self.end_headers()
        self.wfile.write(json.dumps(data).encode('utf-8'))
    
    def do_GET(self):
        if self.path == '/':
            self.send_response(200)
            self.send_header('Content-Type', 'text/html; charset=utf-8')
            self.end_headers()
            self.wfile.write(HTML_TEMPLATE.encode('utf-8'))
        elif self.path == '/api/all':
            items = [{"file": e["file"], "index": e["index"], "item": e["item"], "issues": []} for e in all_items]
            self.send_json({"total": len(items), "items": items})
        elif self.path == '/api/models':
            self.send_json({"models": AVAILABLE_MODELS})
        elif self.path == '/api/translation-apis':
            apis = [{"key": k, "name": v.get("name", k)} for k, v in TRANSLATION_APIS.items()]
            self.send_json({"apis": apis, "default": DEFAULT_API})
        elif self.path == '/api/db/stats':
            self.send_json(get_db_stats())
        else:
            self.send_error(404)
    
    def do_POST(self):
        length = int(self.headers.get('Content-Length', 0))
        body = self.rfile.read(length).decode('utf-8')
        data = json.loads(body) if body else {}
        
        if self.path == '/api/db/init':
            result = sync_db()
            self.send_json(result)
        
        elif self.path == '/api/db/backup':
            result = backup_db()
            self.send_json(result)
        
        elif self.path == '/api/filter':
            rules = data.get("rules", [])
            api_source = data.get("api", "")
            
            global DEFAULT_API, issues_list, all_items
            if api_source:
                DEFAULT_API = api_source
            api_source = api_source or DEFAULT_API
            
            # 直接重新计算而不是使用缓存
            if rules:
                results = []
                for entry in all_items:
                    item = entry["item"]
                    file_key = entry["file"]
                    idx = entry["index"]
                    item_issues = []
                    for rule in rules:
                        if rule in ["cn_empty", "placeholder", "digit_placeholder", "same_content", "low_quality", "length_abnormal"]:
                            if check_single_issue(item, rule):
                                item_issues.append(rule)
                    if item_issues:
                        results.append({"file": file_key, "index": idx, "item": item, "issues": item_issues})
                issues_list = results
            else:
                # 无规则时返回所有条目
                issues_list = [{"file": e["file"], "index": e["index"], "item": e["item"], "issues": []} for e in all_items]
            
            self.send_json({"total": len(issues_list), "issues": issues_list})
        
        elif self.path == '/api/update':
            full_data = load_data()
            file_key, idx, new_cn = data.get("file"), data.get("index"), data.get("cn")
            if file_key in full_data and idx < len(full_data[file_key]):
                full_data[file_key][idx]["cn"] = new_cn
                save_data(full_data)
                
                conn = sqlite3.connect(DB_FILE)
                now = datetime.datetime.now().isoformat()
                is_translated = 1 if new_cn and new_cn.strip() else 0
                issue = check_single_issue_type(full_data[file_key][idx])
                is_fixed = 0 if issue else 1
                conn.execute('''INSERT OR REPLACE INTO translation_status (file_key, index_id, cn, is_translated, is_fixed, issue_type, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?)''',
                          (file_key, idx, new_cn, is_translated, is_fixed, issue, now))
                conn.commit()
                conn.close()
                
                self.send_json({"success": True})
            else:
                self.send_json({"error": "Item not found"})
        
        elif self.path == '/api/translate':
            text = data.get("text", "")
            api = data.get("api", DEFAULT_API)
            self.send_json({"translation": translate_with_api(text, api)})
        
        elif self.path == '/api/token':
            global HF_TOKEN
            HF_TOKEN = data.get("token", "")
            self.send_json({"success": True})
        
        elif self.path == '/api/doubao/config':
            api_url = data.get("url", "")
            session_id = data.get("session", "")
            save_doubao_config(api_url, session_id)
            self.send_json({"success": True})
        
        elif self.path == '/api/doubao/status':
            api_config = TRANSLATION_APIS.get("doubao", {})
            has_url = bool(api_config.get("url", ""))
            has_session = bool(api_config.get("session", ""))
            self.send_json({"configured": has_url and has_session, "has_url": has_url, "has_session": has_session})
        
        else:
            self.send_error(404)

def run_server(port=None):
    if port is None:
        port = SERVER_PORT
    try:
        server = HTTPServer(('0.0.0.0', port), Handler)
        print(f"服务已启动: http://localhost:{port}", flush=True)
        server.serve_forever()
    except Exception as e:
        print(f"启动失败: {e}", flush=True)

if __name__ == "__main__":
    port = None
    for i, arg in enumerate(sys.argv):
        if arg == "--port" and i + 1 < len(sys.argv):
            try:
                port = int(sys.argv[i + 1])
            except:
                pass
    run_server(port)