            const session = document.getElementById('doubao-session').value;
            const resp = await fetch('/api/doubao/config', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({url, session})
            });
            const result = await resp.json();
            if (result.success) {
                alert('保存成功！');
                await checkDoubaoConfig();
            }
        }
        
