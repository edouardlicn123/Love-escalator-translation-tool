            const data = await resp.json();
            const urlRow = document.getElementById('doubao-url-row');
            const sessionRow = document.getElementById('doubao-session-row');
            if (data.configured) {
                urlRow.style.display = 'none';
                sessionRow.style.display = 'none';
                document.getElementById('api-status').textContent = '✓ 已加载';
            } else {
